# Copy to project root as `.env` / `.env.local` (never commit secrets).
# Optional: without DATABASE_URL, bookings stay in memory per Vercel instance.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Required on Vercel / production (min 16 characters). Used to sign dashboard session cookies.
# Vercel: Project → Settings → Environment Variables → add AUTH_SECRET for Production
# (and Preview if you test login on preview URLs), then redeploy.
AUTH_SECRET=change-me-to-a-long-random-string

# Default dashboard super admin is ensured automatically: username superadmin / password 1234
# (change password after first login). If DATABASE_URL is wrong, login will fail — check Vercel logs.
