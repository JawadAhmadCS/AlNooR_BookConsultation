# Copy to project root as `.env` / `.env.local` (never commit secrets).
# Optional: without DATABASE_URL, bookings stay in memory per Vercel instance.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Required in production (min 16 characters). Used to sign dashboard session cookies.
AUTH_SECRET=change-me-to-a-long-random-string

# Default dashboard super admin is created automatically: username superadmin / password 1234
# (change password after first login when using a shared database).
